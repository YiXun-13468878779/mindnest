# ============================================
# MindNest 环境变量配置
# 复制本文件为 .env.local 并填入真实值
# AI 只需配置其中一个（Claude 或 OpenAI）
# ============================================

# ----------- Anthropic Claude API -----------
# 获取：https://console.anthropic.com → API Keys
# 推荐：效果最好
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ----------- OpenAI API（二选一）-----------
# 获取：https://platform.openai.com/api-keys
# 注意：需要有余额，使用 gpt-4o-mini 模型（便宜）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# ----------- Supabase（可选）-----------
# 不配置则使用浏览器本地存储，数据不跨设备同步
# 获取：https://supabase.com → 你的项目 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGcixxxxxxxxxxxxxxxxxxxxxxx
