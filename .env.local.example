# ============================================
# MindNest 环境变量配置
# 复制本文件为 .env.local 并填入真实值
# ============================================

# ----------- Anthropic Claude API -----------
# 获取方式：https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ----------- Supabase -----------
# 获取方式：https://supabase.com → 你的项目 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGcixxxxxxxxxxxxxxxxxxxxxxx

# ----------- Tavily 搜索 API（研究助手用）-----------
# 获取方式：https://tavily.com（免费额度够用）
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxx
